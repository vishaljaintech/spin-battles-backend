# Server Configuration
PORT=8080
RUST_LOG=info

# Game Server URL (REQUIRED — the backend fetches battle results from here)
# Start the game server first: cd game-server && cargo run
GAME_SERVER_URL=http://localhost:8081

# Solana RPC (optional — balance checks fall back to mock data without this)
SOLANA_RPC_URL=https://api.devnet.solana.com

# SBR Token Mint Address (optional — required for real on-chain balance queries)
SBR_TOKEN_MINT=

# Backend Signer Key (optional — auto-generated if not provided)
# The backend auto-generates an ephemeral Ed25519 keypair on startup if this is not set.
# For production or testing with a persistent key, generate with: cargo run --bin keygen
# The corresponding public key must be set as authorized_signer in the deployed program.
# Retrieve it after starting the server: GET /api/rewards/signer-pubkey
BACKEND_SIGNER_PRIVATE_KEY=
